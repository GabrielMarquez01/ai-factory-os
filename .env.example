# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Variables de entorno para Business OS
#
# Copia este archivo: cp .env.example .env.local
# Llena los valores con tus credenciales reales.
# NUNCA subas .env.local a git (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (gratis hasta 500MB / 50K usuarios activos) ─────────────────────
# Consigue estos valores en: supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_ROLE_KEY=eyJh...   # Solo backend — nunca al frontend

# ── IA: Groq (gratis con cuota generosa) ─────────────────────────────────────
# Consigue tu clave en: console.groq.com
GROQ_API_KEY=gsk_...

# ── IA: OpenRouter (pay-per-use, sin costo fijo) ─────────────────────────────
# Consigue tu clave en: openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# ── IA: Anthropic/Claude (opcional, para harness --provider anthropic) ────────
ANTHROPIC_API_KEY=sk-ant-...

# ── IA: Google Gemini / Antigravity (opcional) ───────────────────────────────
GEMINI_API_KEY=AI...

# ── Email: Resend (gratis hasta 100 emails/día) ───────────────────────────────
# Consigue tu clave en: resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hola@tudominio.com   # Debe estar verificado en Resend

# ── Pagos: Polar (alternativa a Stripe, mejor para creadores) ────────────────
# Consigue en: polar.sh → Settings → API
POLAR_ACCESS_TOKEN=polar_...
POLAR_WEBHOOK_SECRET=whsec_...        # Se genera al crear el webhook en Polar

# ── Pagos: Stripe (alternativa, más conocido) ─────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Seguridad: Unsubscribe HMAC ───────────────────────────────────────────────
# Genera con: openssl rand -hex 32
UNSUBSCRIBE_SECRET=genera_uno_con_openssl_rand_hex_32

# ── Tu app ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://tuapp.com   # URL de producción (sin / al final)
NEXT_PUBLIC_APP_NAME=Tu Producto

# ── Harness (testing de agentes) ─────────────────────────────────────────────
# Si tu API corre en un puerto distinto, cambia esto:
LOCAL_API_URL=http://localhost:3000/api/chat

# ─────────────────────────────────────────────────────────────────────────────
# COSTO ESTIMADO EN TIER GRATUITO:
#   Supabase:  $0    (500MB DB + 50K usuarios)
#   Groq:      $0    (cuota diaria generosa con llama-3.3-70b)
#   Resend:    $0    (100 emails/día)
#   Polar:     $0    (sin costo fijo, % sobre ventas)
#   Vercel:    $0    (hobby tier cubre la mayoría de proyectos early-stage)
#
# COSTO EN PRODUCCIÓN CON TRACCIÓN:
#   Solo pagas cuando ya tienes ingresos que lo justifican.
# ─────────────────────────────────────────────────────────────────────────────
